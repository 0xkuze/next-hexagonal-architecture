    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.10",
    "@vitest/coverage-v8": "^3.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.0.10",
    "react": "19.2.0",
